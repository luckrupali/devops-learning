# ============================================================
# .env.example — TEMPLATE for environment variables
# ============================================================
# IMPORTANT: This file is committed to Git (so others know what vars are needed)
# The REAL .env file is NOT committed (it has actual secrets)
#
# To use: Copy this file to .env and fill in real values
#   cp .env.example .env
#   nano .env
# ============================================================

# MongoDB connection string (get this from MongoDB Atlas)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/taskmanager

# Port the server will listen on
PORT=5000
